{
  "name": "dotenv-caster",
  "version": "2.2.8",
  "description": "This package is a tiny package that converts `string | undefined` to certain `primitive types`.",
  "keywords": [
    ".env",
    "dotenv",
    "primitive type",
    "typescript"
  ],
  "homepage": "https://myxogastria0808.github.io/dotenv-caster/",
  "bugs": {
    "url": "https://github.com/Myxogastria0808/dotenv-caster/issues"
  },
  "license": "MIT",
  "author": "Yuki Osada",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Myxogastria0808/dotenv-caster.git"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "COPYING"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "require": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "pub": "npm publish --access=public",
    "unpub": "npm unpublish  dotenv-caster@${npm_config_v}",
    "build": "tsup",
    "typedoc": "npx typedoc",
    "test": "vitest run --typecheck",
    "coverage": "vitest run --coverage --typecheck",
    "ui": "vitest run --ui --typecheck"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "dotenv": "^17.4.2",
    "tsup": "^8.5.1",
    "typedoc": "^0.28.20",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "dotenv": "^17.2.3"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a"
}

