{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "timezone": "Asia/Tokyo",
  "dependencyDashboard": false,
  "prConcurrentLimit": 0,
  "schedule": ["* 0 * * *"],
  "automergeSchedule": ["* * * * 6"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}

